rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // Admin is hardcoded by uid. Kevin: paste your Firebase Auth User UID here
    // (Firebase console -> Authentication -> Users -> your account -> User UID).
    function isAdmin() {
      return isSignedIn() && request.auth.uid in [
        "G7QUZ8Kat1fgyoMjdGKz4DYoVHi1"
      ];
    }

    function profileExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }
    function profileData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    // assignedTrainerId of ownerUid, or null if the profile or the field is
    // missing. The exists() guard + .get(...,null) default keep this from
    // throwing on a missing profile or absent/null field (which would
    // otherwise deny — or worse, error — unpredictably).
    function assignedTrainerOf(ownerUid) {
      return profileExists(ownerUid)
        ? profileData(ownerUid).get('assignedTrainerId', null)
        : null;
    }

    // Is the requester the direct trainer of ownerUid?
    function isDirectTrainer(ownerUid) {
      return assignedTrainerOf(ownerUid) != null
        && request.auth.uid == assignedTrainerOf(ownerUid);
    }

    // Is the requester the head above ownerUid's direct trainer?
    // Guarded so a missing trainer profile can't throw the nested get().
    function isHeadOfTrainer(ownerUid) {
      return assignedTrainerOf(ownerUid) != null
        && profileExists(assignedTrainerOf(ownerUid))
        && request.auth.uid ==
             profileData(assignedTrainerOf(ownerUid)).get('headTrainerId', null);
    }

    function canAccessUserData(ownerUid) {
      return isSignedIn() && (
        // owner and admin first so the common path does NO document lookups
        request.auth.uid == ownerUid
        || isAdmin()
        || isDirectTrainer(ownerUid)
        || isHeadOfTrainer(ownerUid)
      );
    }

    match /users/{uid} {
      // READ: scoped (hardening — was "any signed-in user").
      //  • owner reads own; admin reads any
      //  • TRAINER profiles (head/sub) are a readable directory — needed so a
      //    client can resolve/validate a trainer at join time and show the
      //    trainer's name, and so getMySubTrainers (headTrainerId==me) lists work
      //  • a trainer reads their DIRECT clients (assignedTrainerId==me) — powers
      //    the getMyClients list query
      //  • a head reads profiles where they're the head (headTrainerId==me)
      // Uses resource.data (NOT get()) so the constrained list queries stay valid.
      // Net effect: a client can no longer read another client's profile.
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isAdmin()
        || resource.data.role in ['head_trainer', 'sub_trainer']
        || resource.data.assignedTrainerId == request.auth.uid
        || resource.data.headTrainerId == request.auth.uid
      );

      // CREATE: only your own uid; role must be client or head_trainer ONLY
      // (never admin / sub_trainer); uid field must equal the doc id. Billing
      // can't be self-granted at signup: no entitlements, and subscription may
      // only start as "trial" (Stripe/admin flips it to "active" later).
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role in ['client', 'head_trainer']
        && !request.resource.data.keys().hasAny(['entitlements', 'sessionCredits', 'sessionBillingHold'])
        && request.resource.data.get('subscriptionStatus', 'trial') == 'trial';

      // UPDATE: admin anything; owner may update own profile but MUST NOT
      // change role (blocks self-promotion) and MUST NOT touch the billing /
      // trial fields — the AI budget tier and the Pro food-data gate read
      // subscriptionStatus/entitlements from this doc, so owner-writable
      // billing fields were a self-serve Pro upgrade + infinite-trial hole.
      //
      // S100b adds the SESSION-BILLING fields to the same locked set:
      //  • sessionCredits — prepaid training sessions in the bank. Owner-writable
      //    would be "grant yourself 100 free sessions with your trainer".
      //  • sessionBillingHold — the lockout flag after a declined weekly charge.
      //    Owner-writable would let a client clear their own unpaid hold.
      // Both are written ONLY by the Admin SDK (purchase + settle dispatchers).
      // NOTE: sessionPolicy / sessionPacks are deliberately NOT locked — they are
      // the TRAINER's own cancellation window and price list on their OWN profile,
      // and trainer-set pricing is a core product principle. A trainer editing
      // their own policy can only affect their own business; the fields are read
      // by clients through the existing trainer-directory read rule.
      allow update: if isAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && !request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['subscriptionStatus', 'entitlements', 'trialStartedAt', 'trialLengthDays',
                        'sessionCredits', 'sessionBillingHold'])
        );

      // DELETE: admin only.
      allow delete: if isAdmin();

      // Sensitive per-user app data. Owner, admin, the owner's direct trainer,
      // or the head above that trainer may read AND write.
      match /kv/{docId} {
        allow read, write: if canAccessUserData(uid);
      }

      // PRIVATE per-user storage (S91, notes): OWNER ONLY — deliberately NOT
      // the kv trainer-chain access. A client's private notes are readable by
      // nobody else: not their trainer, not the head, not another client, and
      // not even the admin via the client SDK. (Cloud Functions use the Admin
      // SDK which bypasses rules — the AI tools enforce caller==target for
      // this store in code, so the AI can never surface private notes to a
      // trainer either.)
      match /privkv/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Is trainerUid actually the trainer over clientUid — either their direct
    // trainer (assignedTrainerId) or the head above that trainer? Pair check
    // independent of who the requester is (messaging: either side may create).
    function isTrainerOf(trainerUid, clientUid) {
      return assignedTrainerOf(clientUid) != null && (
        assignedTrainerOf(clientUid) == trainerUid
        || (profileExists(assignedTrainerOf(clientUid))
            && profileData(assignedTrainerOf(clientUid)).get('headTrainerId', null) == trainerUid)
      );
    }

    // ── In-app messaging (S90, docs/MESSAGING-PLAN.md) ────────────────────────
    // One thread per linked trainer↔client pair; doc id = "{trainerUid}_{clientUid}"
    // (deterministic — no lookup needed). Only the two participants can see it;
    // creating one requires the pair to be REALLY linked. Messages are append-only
    // (no edit/delete in v1 — keeps the rules tight; admin can delete to moderate).
    // Note: the unread map is a UX convenience between two already-linked people —
    // field-level unread math is deliberately not policed (worst case: a badge).
    match /threads/{tid} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.keys().hasOnly(['participants', 'trainerUid', 'clientUid', 'lastMsg', 'lastFrom', 'updatedAt', 'unread'])
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] == request.resource.data.trainerUid
        && request.resource.data.participants[1] == request.resource.data.clientUid
        && tid == request.resource.data.trainerUid + '_' + request.resource.data.clientUid
        && isTrainerOf(request.resource.data.trainerUid, request.resource.data.clientUid);
      // participants/trainerUid/clientUid are immutable — only the message
      // metadata may change, and lastFrom must be one of the two participants.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMsg', 'lastFrom', 'updatedAt', 'unread'])
        && request.resource.data.get('lastFrom', '') in resource.data.participants;
      allow delete: if isAdmin();

      match /msgs/{mid} {
        function threadData() {
          return get(/databases/$(database)/documents/threads/$(tid)).data;
        }
        allow read: if isSignedIn() && request.auth.uid in threadData().participants;
        allow create: if isSignedIn()
          && request.auth.uid in threadData().participants
          && request.resource.data.from == request.auth.uid
          && request.resource.data.keys().hasOnly(['from', 'text', 'ts'])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update: if false; // append-only
        allow delete: if isAdmin();
      }
    }

    // ── Training sessions / appointments (S100, docs/SESSIONS-BILLING-PLAN.md) ─
    // One doc per booked session at sessions/{sid}, readable only by the two
    // people in it. The TRAINER books (a client can't create sessions for
    // themselves); either side may cancel. Queries use
    // where('participants','array-contains', myUid) — a single-field index, so
    // no composite index is needed; ordering happens client-side.
    //
    // ⚠️ BILLING FIELDS ARE SERVER-ONLY. settled/settledAt/chargeId/
    // completedAt/settleAttempts decide whether real money moves, so NEITHER
    // participant may write them from the client SDK — only the Admin SDK
    // (the scheduled settle dispatcher) can. Same lesson as subscriptionStatus
    // in S85: if a field gates money or entitlement, the owner can't own it.
    match /sessions/{sid} {
      function bookingFields() {
        return ['participants', 'trainerUid', 'clientUid', 'startAt', 'durationMin',
                'status', 'title', 'location', 'priceCents',
                'createdBy', 'createdAt', 'updatedAt',
                'cancelledBy', 'cancelledAt', 'cancelReason'];
      }
      // Fields a CLIENT is allowed to touch — cancelling their own session and
      // nothing else (they can't move it, re-price it, or un-cancel it).
      function clientCancelFields() {
        return ['status', 'cancelledBy', 'cancelledAt', 'cancelReason', 'updatedAt'];
      }
      function isParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      function changed() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      // ⚠️ cancelledAt decides whether a LATE-CANCEL FEE applies, so it cannot be
      // a number the canceller just types. Without this, a client cancelling 1
      // hour before a session could write cancelledAt = "3 days ago" and slip
      // outside the trainer's window for free. Pinned to server time
      // (request.time) with ±5 min of slack for honest device-clock skew —
      // far too tight to fake the hours-scale backdating the fee turns on, and
      // it binds the TRAINER symmetrically so neither side can rewrite history.
      function cancelStampHonest() {
        return !changed().hasAny(['cancelledAt'])
          || (request.resource.data.cancelledAt is number
              && request.resource.data.cancelledAt >= request.time.toMillis() - 300000
              && request.resource.data.cancelledAt <= request.time.toMillis() + 300000);
      }
      // The identity of the booking can never be rewritten after creation.
      function identityIntact() {
        return request.resource.data.trainerUid == resource.data.trainerUid
          && request.resource.data.clientUid == resource.data.clientUid
          && request.resource.data.participants == resource.data.participants
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && request.resource.data.get('createdAt', 0) == resource.data.get('createdAt', 0);
      }

      allow read: if isParticipant() || isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(bookingFields())
        && request.resource.data.keys().hasAll(['participants', 'trainerUid', 'clientUid', 'startAt', 'durationMin', 'status'])
        // Only the trainer books, and only for a client really linked to them.
        && request.auth.uid == request.resource.data.trainerUid
        && isTrainerOf(request.resource.data.trainerUid, request.resource.data.clientUid)
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants[0] == request.resource.data.trainerUid
        && request.resource.data.participants[1] == request.resource.data.clientUid
        && request.resource.data.trainerUid != request.resource.data.clientUid
        // A new booking always starts scheduled and unsettled.
        && request.resource.data.status == 'scheduled'
        && request.resource.data.startAt is number
        && request.resource.data.durationMin is number
        && request.resource.data.durationMin > 0
        && request.resource.data.durationMin <= 480
        && request.resource.data.get('priceCents', 0) is number
        && request.resource.data.get('priceCents', 0) >= 0
        && request.resource.data.get('priceCents', 0) <= 500000;

      // TRAINER: may reschedule, re-price, retitle, or cancel — but never write
      // a billing field and never rewrite whose session it is.
      allow update: if isParticipant()
        && request.auth.uid == resource.data.trainerUid
        && changed().hasOnly(bookingFields())
        && identityIntact()
        && cancelStampHonest()
        && request.resource.data.status in ['scheduled', 'cancelled']
        && request.resource.data.durationMin is number
        && request.resource.data.durationMin > 0
        && request.resource.data.durationMin <= 480;

      // CLIENT: cancel only. Status may go to 'cancelled' and nothing else may move.
      allow update: if isParticipant()
        && request.auth.uid == resource.data.clientUid
        && changed().hasOnly(clientCancelFields())
        && identityIntact()
        && cancelStampHonest()
        && request.resource.data.status == 'cancelled';

      // Deleting would erase billing history — cancel instead. Admin only.
      allow delete: if isAdmin();
    }

    // Friendly invite-code lookup: doc id = the CODE, data = { trainerUid }.
    // Lets a not-yet-linked client resolve a code to a trainer with a single
    // doc read instead of querying the whole users collection — which is what
    // lets us tighten profile-doc reads later (docs/BLAZE_MIGRATION.md step 5).
    // A code can only be claimed by the trainer it points to, and once claimed
    // cannot be overwritten by anyone else (no code hijacking).
    match /inviteCodes/{code} {
      // GET by code is how a client resolves an invite — but collection-wide
      // LIST would let any signed-in user harvest every code → trainer mapping
      // (codes are semi-secret capability tokens). The app only ever does
      // point-gets by doc id.
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // create only when the doc doesn't exist yet, pointing at yourself,
      // with exactly the expected fields
      allow create: if isSignedIn()
        && request.resource.data.trainerUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['trainerUid', 'createdAt']);
      // update only by the trainer the code already points to (refresh), still self
      allow update: if isSignedIn()
        && resource.data.trainerUid == request.auth.uid
        && request.resource.data.trainerUid == request.auth.uid;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.trainerUid == request.auth.uid);
    }
  }
}
